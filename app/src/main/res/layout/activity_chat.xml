<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"> <LinearLayout
    android:id="@+id/chatHeader"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_alignParentTop="true"
    android:background="#FFFFFF"
    android:elevation="4dp"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp"
    android:paddingVertical="16dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/btnBackChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Back"
        android:textColor="#1142D4"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingVertical="8dp"
        android:paddingEnd="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"/>

    <androidx.cardview.widget.CardView
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardCornerRadius="22dp"
        app:cardBackgroundColor="#EEF3FF"
        app:cardElevation="0dp"
        android:layout_marginEnd="12dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp"
            android:src="@drawable/ic_user"
            app:tint="#1142D4" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvChatReceiverName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textColor="#0F172A"
        android:textSize="18sp"
        android:textStyle="bold" />
</LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerChat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/chatHeader"
        android:layout_above="@id/layoutInput"
        android:padding="16dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etMessageChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="55dp"
            android:layout_weight="1"
            android:background="@drawable/bg_rounded_input"
            android:hint="Type a message..."
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            android:textColor="#0F172A"
            android:textColorHint="#94A3B8"
            android:textSize="16sp"
            android:maxLines="4"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnSendMessage"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginStart="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="#1142D4"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:src="@drawable/ic_send"
                app:tint="#FFFFFF"
                android:layout_marginStart="3dp"/> </androidx.cardview.widget.CardView>
    </LinearLayout>
</RelativeLayout>