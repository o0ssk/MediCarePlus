<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:elevation="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text="Cancel"
                android:textColor="#1142D4"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Add Medication"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/step1Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1. Details"
                android:textColor="#1142D4"
                android:textStyle="bold"
                android:gravity="center"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/step2Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2. Schedule"
                android:textColor="#94A3B8"
                android:gravity="center"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/step3Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3. Reminders"
                android:textColor="#94A3B8"
                android:gravity="center"
                android:textSize="13sp"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/stepProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="3"
            android:progress="1"
            android:progressTint="#1142D4"
            android:backgroundTint="#E2E8F0"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomActionArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:padding="20dp"
        android:elevation="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextStep"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Next Step →"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#1142D4"
            app:cornerRadius="16dp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerLayout"
        android:layout_above="@id/bottomActionArea">

        <ScrollView
            android:id="@+id/layoutStep1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:cardBackgroundColor="#EEF3FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#C7D2FE"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_scan"
                            app:tint="#1142D4" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scan Prescription"
                                android:textColor="#1142D4"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Use camera to auto-fill details."
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Medication Details"
                    android:textColor="#0F172A"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Drug Name" android:textStyle="bold" android:textColor="#0F172A" android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etDrugName"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_rounded_input"
                    android:hint="Search drug name (e.g. Lisinopril)"
                    android:textColor="#0F172A"
                    android:padding="16dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medication Type" android:textStyle="bold" android:textColor="#0F172A" android:layout_marginBottom="8dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="16dp">

                    <RadioGroup
                        android:id="@+id/rgMedType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbPill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:checked="true"
                            android:drawableStart="@drawable/ic_pill"
                            android:drawablePadding="8dp"
                            android:buttonTint="#1142D4"
                            android:text="Pill" />

                        <RadioButton
                            android:id="@+id/rbSyrup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Syrup"
                            android:drawableStart="@drawable/ic_syrup"
                            android:drawablePadding="8dp"
                            android:buttonTint="#1142D4"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rbInjection"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Injection"
                            android:drawableStart="@drawable/ic_injection"
                            android:drawablePadding="8dp"
                            android:buttonTint="#1142D4"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rbInhaler"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inhaler"
                            android:drawableStart="@drawable/ic_inhaler"
                            android:drawablePadding="8dp"
                            android:buttonTint="#1142D4"
                            android:layout_marginEnd="16dp"/>

                        <RadioButton
                            android:id="@+id/rbDrops"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Drops"
                            android:drawableStart="@drawable/ic_drops"
                            android:buttonTint="#1142D4"
                            android:drawablePadding="8dp"/>

                    </RadioGroup>
                </HorizontalScrollView>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dosage Strength" android:textStyle="bold" android:textColor="#0F172A" android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <EditText
                        android:id="@+id/etDosageValue"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="2"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_rounded_input"
                        android:hint="e.g. 500"
                        android:textColor="#0F172A"
                        android:inputType="numberDecimal"
                        android:padding="16dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_rounded_input"
                        android:gravity="center"
                        android:text="mg"
                        android:drawableEnd="@drawable/ic_chevron_right"
                        android:drawablePadding="4dp"
                        app:drawableTint="#64748B"
                        android:paddingHorizontal="16dp"
                        android:textColor="#0F172A"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nickname (Optional)" android:textStyle="bold" android:textColor="#0F172A" android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etNickname"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_rounded_input"
                    android:hint="e.g. Mom's Heart Pill"
                    android:textColor="#0F172A"
                    android:padding="16dp" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/layoutStep2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Frequency"
                    android:textColor="#0F172A"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardBackgroundColor="#EEF3FF"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#1142D4"
                        app:strokeWidth="2dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_calendar"
                                android:layout_marginBottom="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Daily" android:textColor="#1142D4" android:textStyle="bold"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#E2E8F0"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_calendar_month"
                                android:layout_marginBottom="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Specific Days" android:textColor="#64748B" android:textStyle="bold"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Daily Time"
                    android:textColor="#0F172A"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etTimePicker"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_rounded_input"
                    android:hint="Set Time (e.g. 08:00 AM)"
                    android:textColor="#0F172A"
                    android:inputType="time"
                    android:padding="16dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_morning"
                            app:tint="#F59E0B"
                            android:layout_marginEnd="16dp"/>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MORNING" android:textColor="#64748B" android:textSize="12sp" android:textStyle="bold"/>
                            <TextView android:id="@+id/tvDisplayTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#0F172A" android:textSize="20sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1 dose" android:textColor="#1142D4" android:textStyle="bold" android:background="@drawable/bg_rounded_id" android:padding="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/layoutStep3"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reminders &amp; Inventory"
                    android:textColor="#0F172A"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Notification Sound"
                    android:textColor="#0F172A"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:cardBackgroundColor="#EEF3FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1142D4"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_notifications_active"
                            app:tint="#1142D4"
                            android:layout_marginEnd="16dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gentle Chime" android:textColor="#0F172A" android:textSize="16sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Soft reminder. Best for vitamins." android:textColor="#64748B" android:textSize="12sp"/>
                        </LinearLayout>
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_play"
                            app:tint="#1142D4"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Track Inventory"
                    android:textColor="#0F172A"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Current Pill Count" android:textStyle="bold" android:textColor="#64748B"/>
                    <EditText
                        android:layout_width="100dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_rounded_input"
                        android:text="30"
                        android:gravity="center"
                        android:inputType="number"
                        android:textStyle="bold"
                        android:textColor="#0F172A"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="40dp"> <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Low Stock Alert Threshold" android:textStyle="bold" android:textColor="#64748B"/>
                    <EditText
                        android:layout_width="100dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_rounded_input"
                        android:text="5"
                        android:gravity="center"
                        android:inputType="number"
                        android:textStyle="bold"
                        android:textColor="#0F172A"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </FrameLayout>
</RelativeLayout>