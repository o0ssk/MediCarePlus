<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/btnBackCaregiverProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:text="← Back"
            android:textColor="#1142D4"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingVertical="8dp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"/>

        <androidx.cardview.widget.CardView
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:cardBackgroundColor="#EEF3FF"
            app:cardCornerRadius="70dp"
            app:cardElevation="0dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="32dp"
                android:src="@drawable/ic_user"
                app:tint="#1142D4" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Caregiver Profile"
            android:textColor="#0F172A"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CARE MANAGER NAME"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#94A3B8"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etCaregiverProfileName"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_rounded_input"
                    android:layout_marginBottom="20dp"
                    android:paddingHorizontal="16dp"
                    android:textSize="16sp"
                    android:textColor="#0F172A"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCOUNT EMAIL"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#94A3B8"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:id="@+id/tvProfileEmail"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_rounded_input"
                    android:text="caregiver@medicare.com"
                    android:textColor="#64748B"
                    android:textSize="16sp"
                    android:layout_marginBottom="20dp"
                    android:paddingHorizontal="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CARE MANAGER ID"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#94A3B8"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvCaregiverProfileId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="ID: Loading..."
                    android:textColor="#1142D4"
                    android:background="@drawable/bg_rounded_id"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnSaveCaregiverProfile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Save Profile Updates ✓"
            android:backgroundTint="#1142D4"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:cornerRadius="16dp"/>

        <Button
            android:id="@+id/btnLogoutCaregiverProfile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Log Out"
            android:backgroundTint="#FEF2F2"
            android:textColor="#DC2626"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:cornerRadius="16dp"
            app:strokeColor="#FCA5A5"
            app:strokeWidth="1dp"/>

    </LinearLayout>
</ScrollView>